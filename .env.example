# ============================================================================
# Sleep Eazzzy — environment variables
# ============================================================================
#
# Copy this file to .env.local for local development.
# Set the same vars in the Vercel dashboard (Settings → Environment Variables)
# for production. Without these, the site continues to work fully but with no
# authentication — sign-in button disappears, progress stays local-only.
#
# All NEXT_PUBLIC_* values are baked into the client bundle and are not secret.
# Anything without that prefix MUST stay server-side.
# ============================================================================

# --- Clerk (authentication) ---------------------------------------------------
# Sign up at https://clerk.com → create an application → Developers → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase (database) ------------------------------------------------------
# Sign up at https://supabase.com → create a project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx.xxx

# Server-only — bypasses Row Level Security. Used by /api/users/sync.
# Vercel: add this as a non-public env var. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx.xxx

# --- Optional Clerk URL overrides --------------------------------------------
# Where to redirect after sign-in / sign-up. Defaults to / which redirects to /en.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/en
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/en
